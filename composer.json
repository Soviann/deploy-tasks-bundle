{
    "name": "soviann/deploy-tasks-bundle",
    "description": "One-time deploy task runner for Symfony applications",
    "type": "symfony-bundle",
    "license": "MIT",
    "homepage": "https://github.com/Soviann/deploy-tasks-bundle",
    "authors": [
        {
            "name": "Nicolas Vasse",
            "email": "vasse.nicolas@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/Soviann/deploy-tasks-bundle/issues",
        "source": "https://github.com/Soviann/deploy-tasks-bundle"
    },
    "keywords": ["symfony", "deploy", "tasks", "migration", "bundle"],
    "require": {
        "php": ">=8.2",
        "psr/clock": "^1.0",
        "psr/log": "^3.0",
        "symfony/config": "^6.4 || ^7.0",
        "symfony/console": "^6.4 || ^7.0",
        "symfony/dependency-injection": "^6.4 || ^7.0",
        "symfony/event-dispatcher-contracts": "^2.5 || ^3.0",
        "symfony/filesystem": "^6.4 || ^7.0",
        "symfony/http-kernel": "^6.4 || ^7.0"
    },
    "require-dev": {
        "doctrine/dbal": "^4.3",
        "friendsofphp/php-cs-fixer": "^3.0",
        "infection/infection": "^0.32",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^10.5 || ^11.0",
        "symfony/clock": "^6.4 || ^7.0",
        "symfony/dotenv": "^6.4 || ^7.0",
        "symfony/event-dispatcher": "^6.4 || ^7.0",
        "symfony/framework-bundle": "^6.4 || ^7.0",
        "symfony/lock": "^6.4 || ^7.0",
        "symfony/phpunit-bridge": "^8.0.8",
        "symfony/process": "^6.4 || ^7.0"
    },
    "suggest": {
        "doctrine/dbal": "Required (^4.3) for the database storage backend",
        "symfony/event-dispatcher": "Required for task lifecycle events",
        "symfony/lock": "Required for concurrent execution protection",
        "symfony/process": "Required by ProcessRunnerTrait for tasks that shell out to external commands"
    },
    "conflict": {
        "doctrine/dbal": "<4.3",
        "symfony/event-dispatcher": "<6.4",
        "symfony/lock": "<6.4",
        "symfony/process": "<6.4"
    },
    "autoload": {
        "psr-4": {
            "Soviann\\DeployTasksBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Soviann\\DeployTasksBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "check": [
            "@cs",
            "@phpstan",
            "@test"
        ],
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "infection": "infection --threads=max",
        "phpstan": "phpstan analyse",
        "test": "phpunit",
        "test-functional": "phpunit --testsuite Functional",
        "test-unit": "phpunit --testsuite Unit"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    }
}
